SYSTEM_FROM_EMAIL=
SYSTEM_FROM_NAME=Formlet
SYSTEM_SMTP_SECURE=true

# Stripe Billing
STRIPE_MODE=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
